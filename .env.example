# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecnet_email_agent
DB_USER=your_db_user
DB_PASS=your_db_password

# ── Application ──────────────────────────────────────────────────────────────
APP_URL=http://localhost:5173
APP_ENV=development
APP_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_SECRET=CHANGE_THIS_TO_A_DIFFERENT_RANDOM_64_CHAR_STRING
JWT_EXPIRY=86400

# ── Google / Gemini ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Default GCP OAuth (per-org overrides stored in DB take priority) ──────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=${APP_URL}/api/gmail/callback

# ── Encryption (for storing OAuth tokens in DB) ───────────────────────────────
# Must be exactly 32 bytes (64 hex chars):
ENCRYPTION_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING

# ── Primary Admin ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_this_password
